NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
POSTGRES_URL=postgres://...
MCP_API_KEY=your-secret-key-here
MCP_OWNER_USER_ID=user_xxxxxxxxxxxxxxxxxxxx

# Remote HTTP MCP server (mcp-server-http.ts)
# Shared secret that inbound MCP clients must supply as `Authorization: Bearer <value>`
MCP_SERVER_SECRET=your-mcp-server-secret-here
# Base URL of the deployed garden app (used by the remote MCP server to call /api/mcp/*)
GARDEN_API_URL=https://this-year-garden.vercel.app
